{
    "name": "house-rent",
    "version": "1.0.0",
    "description": "HomeHive - MERN Stack House Rent Application",
    "private": true,
    "scripts": {
        "client": "cd client && npm run dev",
        "server": "cd backend && npm start",
        "dev": "concurrently \"npm run client\" \"npm run server\"",
        "install-all": "cd client && npm install && cd ../backend && npm install",
        "build": "cd client && npm run build"
    },
    "devDependencies": {
        "concurrently": "^9.1.0"
    }
}